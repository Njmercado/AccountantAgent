# ── PostgreSQL ─────────────────────────────────────────────────────
POSTGRES_USER=accountant
POSTGRES_PASSWORD=changeme
POSTGRES_DB=accountant_db
POSTGRES_PORT=5432

# ── pgAdmin ────────────────────────────────────────────────────────
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=changeme
PGADMIN_PORT=5050

# ── Database URI (for your app) ────────────────────────────────────
DATABASE_URL=postgresql://accountant:changeme@localhost:5432/accountant_db
